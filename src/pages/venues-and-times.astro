---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { getCollection, getEntry, render } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const page = await getEntry('pages', 'times');
const { title, description, outdoor_heading, outdoor_text, indoor_heading, indoor_text } = page!.data;

const venues = await getCollection('venues');
const sortedVenues = venues.sort((a, b) => a.data.order - b.data.order);
const renderedVenues = await Promise.all(
  sortedVenues.map(async (venue) => {
    const { Content } = await render(venue);
    return { venue, Content };
  })
);
---

<BaseLayout title={title} description={description}>
  
    <Hero
      image={`${base}/images/heroes/home1.jpg`}
      title="Venues & Times"
      subtitle="Where and when we shoot"
    />

    <!-- Shooting Times -->
    <section class="times" aria-labelledby="times-heading">
      <div class="container">
        <SectionHeading title="Shooting Times" subtitle="We meet regularly throughout the year" />

        <div class="season-cards">
          <article class="season-card outdoor">
            <div class="season-header">
              <span class="season-pill outdoor-pill">Outdoor</span>
              <h3>{outdoor_heading}</h3>
            </div>
            {outdoor_text!.split('\n\n').map((paragraph: string) => (
              <p>{paragraph}</p>
            ))}
            <table>
              <caption class="visually-hidden">Outdoor shooting schedule</caption>
              <thead>
                <tr>
                  <th scope="col">Day</th>
                  <th scope="col">Time</th>
                  <th scope="col">Venue</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>Wednesday</td>
                  <td>From approx. 6:30 pm</td>
                  <td>York RI Sports Ground</td>
                </tr>
                <tr>
                  <td>Friday</td>
                  <td>From approx. 6:30 pm</td>
                  <td>York RI Sports Ground</td>
                </tr>
              </tbody>
            </table>
          </article>

          <article class="season-card indoor">
            <div class="season-header">
              <span class="season-pill indoor-pill">Indoor</span>
              <h3>{indoor_heading}</h3>
            </div>
            {indoor_text!.split('\n\n').map((paragraph: string) => (
              <p>{paragraph}</p>
            ))}
            <table>
              <caption class="visually-hidden">Indoor shooting schedule</caption>
              <thead>
                <tr>
                  <th scope="col">Day</th>
                  <th scope="col">Time</th>
                  <th scope="col">Venue</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>Monday</td>
                  <td>6:50 pm</td>
                  <td>Askham Bryan College</td>
                </tr>
                <tr>
                  <td>Friday</td>
                  <td>6:50 pm</td>
                  <td>Acomb Methodist Church Hall</td>
                </tr>
              </tbody>
            </table>
          </article>
        </div>
      </div>
    </section>

    <!-- Venues -->
    <section class="venues" aria-labelledby="venues-heading">
      <div class="container">
        <SectionHeading title="Our Venues" subtitle="Three venues across York" />

        <div class="venue-list">
          {renderedVenues.map(({ venue, Content }, index) => {
            const isEven = index % 2 === 1;
            return (
              <article class={`venue-card ${isEven ? 'venue-card--reversed' : ''}`}>
                <div class="venue-map">
                  <figure>
                    <img
                      src={`${base}${venue.data.mapImage}`}
                      alt={`Map showing location of ${venue.data.title}, ${venue.data.address}`}
                      width="500"
                      height="400"
                      loading="lazy"
                      decoding="async"
                    />
                  </figure>
                </div>
                <div class="venue-info">
                  <div class="venue-header">
                    <h3>{venue.data.title}</h3>
                    <span class={`venue-type-pill ${venue.data.type === 'outdoor' ? 'pill-outdoor' : 'pill-indoor'}`}>
                      {venue.data.type === 'outdoor' ? 'Outdoor' : 'Indoor'}
                    </span>
                  </div>
                  <address class="venue-address">
                    {venue.data.address}, {venue.data.postcode}
                  </address>
                  <div class="venue-body">
                    <Content />
                  </div>
                  <a
                    href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(venue.data.address + ', ' + venue.data.postcode)}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="directions-link"
                  >
                    Get directions
                    <span class="visually-hidden"> to {venue.data.title} (opens in new tab)</span>
                    <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                  </a>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <!-- CTA Band -->
    <section class="cta-band" aria-labelledby="cta-heading">
      <div class="container">
        <h2 id="cta-heading">Come and Visit Us</h2>
        <p>New members and visitors are always welcome. Get in touch to arrange a visit.</p>
        <a href={`${base}/contact`} class="btn-gold">Contact Us</a>
      </div>
    </section>
  
</BaseLayout>

<style>
  .container {
    width: 100%;
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--space-4);
  }

  @media (min-width: 768px) {
    .container {
      padding-inline: var(--space-8);
    }
  }

  /* Times Section */
  .times {
    padding: var(--space-16) 0;
    background: var(--color-bg);
  }

  .season-cards {
    display: grid;
    gap: var(--space-6);
    margin-top: var(--space-8);
  }

  @media (min-width: 768px) {
    .season-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .season-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    box-shadow: var(--shadow-sm);
  }

  .season-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }

  .season-header h3 {
    font-family: var(--font-heading);
    font-size: var(--text-h3);
    font-weight: 600;
    color: var(--color-text);
    margin: 0;
  }

  .season-pill {
    display: inline-block;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 4px 12px;
    border-radius: var(--radius-full);
  }

  .outdoor-pill {
    background: #e8f5ee;
    color: #0F5038;
  }

  .indoor-pill {
    background: #dbeafe;
    color: #1e40af;
  }

  .season-card p {
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: 1.6;
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  .season-card table {
    width: 100%;
    border-collapse: collapse;
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-top: var(--space-4);
  }

  .season-card thead {
    background: var(--color-green-800);
  }

  .season-card th {
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 600;
    color: white;
    text-align: left;
    padding: var(--space-3) var(--space-4);
  }

  .season-card td {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text-muted);
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  .season-card tbody tr:nth-child(even) td {
    background: var(--color-bg-alt);
  }

  .season-card tbody tr:last-child td {
    border-bottom: none;
  }

  /* Venues Section */
  .venues {
    padding: var(--space-16) 0;
    background: var(--color-bg-alt);
  }

  .venue-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
    margin-top: var(--space-8);
  }

  .venue-card {
    display: grid;
    gap: var(--space-6);
    background: var(--color-bg);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--color-border);
  }

  @media (min-width: 768px) {
    .venue-card {
      grid-template-columns: 1fr 1fr;
    }

    .venue-card--reversed {
      direction: rtl;
    }

    .venue-card--reversed > * {
      direction: ltr;
    }
  }

  .venue-map figure {
    margin: 0;
    height: 100%;
  }

  .venue-map img {
    width: 100%;
    height: 100%;
    min-height: 250px;
    object-fit: cover;
    display: block;
  }

  .venue-info {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .venue-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-bottom: var(--space-3);
  }

  .venue-header h3 {
    font-family: var(--font-heading);
    font-size: var(--text-h3);
    font-weight: 600;
    color: var(--color-text);
    margin: 0;
  }

  .venue-type-pill {
    display: inline-block;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 4px 12px;
    border-radius: var(--radius-full);
  }

  .pill-outdoor {
    background: #e8f5ee;
    color: #0F5038;
  }

  .pill-indoor {
    background: #dbeafe;
    color: #1e40af;
  }

  .venue-address {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-style: normal;
    margin-bottom: var(--space-4);
  }

  .venue-body {
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: 1.6;
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  .venue-body :global(h2) {
    font-family: var(--font-heading);
    font-size: var(--text-h4);
    font-weight: 600;
    color: var(--color-text);
    margin-top: var(--space-4);
    margin-bottom: var(--space-2);
  }

  .venue-body :global(p) {
    margin-bottom: var(--space-3);
  }

  .directions-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-green-600);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    transition: color var(--transition-fast);
  }

  .directions-link:hover {
    color: var(--color-green-800);
  }

  .directions-link:focus-visible {
    outline: 2px solid var(--color-gold-600);
    outline-offset: 2px;
  }

  /* CTA Band */
  .cta-band {
    padding: var(--space-16) 0;
    background: var(--color-green-800);
    text-align: center;
  }

  .cta-band h2 {
    font-family: var(--font-heading);
    font-size: var(--text-h1);
    font-weight: 700;
    color: white;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    margin-bottom: var(--space-4);
  }

  .cta-band p {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: var(--space-8);
    max-width: 36rem;
    margin-inline: auto;
  }

  .btn-gold {
    display: inline-block;
    background: var(--color-gold-600);
    color: var(--color-green-900);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--text-sm);
    letter-spacing: 0.03em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 16px 36px;
    border-radius: var(--radius-md);
    transition: background var(--transition-fast), transform var(--transition-fast);
  }

  .btn-gold:hover {
    background: var(--color-gold-500);
    transform: translateY(-1px);
  }

  .btn-gold:focus-visible {
    outline: 2px solid white;
    outline-offset: 2px;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .directions-link,
    .btn-gold {
      transition-duration: 0.01ms !important;
    }
  }
</style>
