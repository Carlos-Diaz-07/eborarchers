---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { getEntry, render } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const page = await getEntry('pages', 'join-us');
const { title, description, fees, beginners_price } = page!.data;
const { Content } = await render(page!);
---

<BaseLayout title="Join Us" description={description}>
  
    <Hero
      image={`${base}/images/heroes/arrows-in-the-ground.jpg`}
      title="Join Us"
      subtitle="Start your archery journey"
    />

    <!-- How to Join -->
    <section class="how-to-join" aria-labelledby="how-heading">
      <div class="container">
        <SectionHeading id="how-heading" title="How to Join" subtitle="Three steps to becoming a member" />

        <div class="steps">
          <div class="step">
            <div class="step-number" aria-hidden="true">1</div>
            <h3>Complete a Beginners Course</h3>
            <p>
              Take our six-session beginners course to learn the fundamentals of archery safely.
              All equipment is provided.
            </p>
          </div>
          <div class="step">
            <div class="step-number" aria-hidden="true">2</div>
            <h3>Register with Archery GB</h3>
            <p>
              All members must be registered with Archery GB, Northern Counties Archery Society (NCAS)
              and Yorkshire Archery Association (YAA).
            </p>
          </div>
          <div class="step">
            <div class="step-number" aria-hidden="true">3</div>
            <h3>Pay Your Membership</h3>
            <p>
              Annual membership includes subscriptions to AGB, NCAS and YAA, giving you access
              to all club sessions and facilities.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Membership Fees -->
    <section class="fees" aria-labelledby="fees-heading">
      <div class="container">
        <SectionHeading id="fees-heading" title="Membership Fees" subtitle="Annual membership includes AGB, NCAS and YAA subscriptions" />

        <div class="fees-table-wrapper">
          <table class="fees-table">
            <caption class="visually-hidden">Annual membership fees</caption>
            <thead>
              <tr>
                <th scope="col">Category</th>
                <th scope="col">Eligibility</th>
                <th scope="col">Annual Fee</th>
              </tr>
            </thead>
            <tbody>
              {fees!.map((fee) => (
                <tr>
                  <td><strong>{fee.category}</strong></td>
                  <td>{fee.notes}</td>
                  <td class="fee-amount">{fee.price}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="fees-note">
          All fees include annual subscriptions to Archery GB, NCAS and YAA.
        </p>
      </div>
    </section>

    <!-- Beginners Course -->
    <section class="beginners" aria-labelledby="beginners-heading">
      <div class="container">
        <SectionHeading id="beginners-heading" title="Beginners Courses" subtitle="Your first step into archery" />

        <div class="beginners-layout">
          <div class="beginners-text">
            <Content />
          </div>
          <div class="course-card">
            <h3>Course Details</h3>
            <dl class="course-details">
              <div class="detail-row">
                <dt>Duration</dt>
                <dd>6 sessions (one evening per week over 6 consecutive weeks)</dd>
              </div>
              <div class="detail-row">
                <dt>Cost</dt>
                <dd>&pound;{beginners_price} per person</dd>
              </div>
              <div class="detail-row">
                <dt>Equipment</dt>
                <dd>All equipment provided</dd>
              </div>
              <div class="detail-row">
                <dt>Experience</dt>
                <dd>No previous experience required</dd>
              </div>
            </dl>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact Form -->
    <section class="contact-section" aria-labelledby="contact-heading">
      <div class="container">
        <SectionHeading id="contact-heading" title="Get in Touch" subtitle="Interested in joining? Send us a message" />

        <div class="form-wrapper">
          <form
            action="https://api.web3forms.com/submit"
            method="POST"
            class="contact-form"
            id="join-form"
            novalidate
          >
            <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE" />
            <input type="hidden" name="subject" value="New membership enquiry from Ebor Archers website" />
            <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

            <p class="required-legend">Fields marked with * are required</p>

            <div class="form-group">
              <label for="name">Your name *</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                minlength="2"
                autocomplete="name"
              />
            </div>

            <div class="form-group">
              <label for="email">Email address *</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
              />
            </div>

            <div class="form-group">
              <label for="phone">Phone number (optional)</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                autocomplete="tel"
              />
            </div>

            <div class="form-group">
              <label for="message">Your message *</label>
              <textarea
                id="message"
                name="message"
                required
                minlength="10"
                rows="5"
              ></textarea>
            </div>

            <button type="submit" class="btn-primary">Send Message</button>

            <div id="form-status" role="status" aria-live="polite" class="form-status"></div>
          </form>
        </div>
      </div>
    </section>
  
</BaseLayout>

<script>
  const form = document.getElementById('join-form') as HTMLFormElement;
  const status = document.getElementById('form-status') as HTMLDivElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Clear previous errors
    form.querySelectorAll('.error-message').forEach((el) => el.remove());
    form.querySelectorAll('[aria-invalid]').forEach((el) => el.removeAttribute('aria-invalid'));

    // Validate
    const errors: { field: HTMLInputElement | HTMLTextAreaElement; message: string }[] = [];
    const name = form.querySelector('#name') as HTMLInputElement;
    const email = form.querySelector('#email') as HTMLInputElement;
    const message = form.querySelector('#message') as HTMLTextAreaElement;

    if (!name.value.trim() || name.value.trim().length < 2) {
      errors.push({ field: name, message: 'Please enter your name (at least 2 characters)' });
    }
    if (!email.value.trim() || !email.validity.valid) {
      errors.push({ field: email, message: 'Please enter a valid email address, e.g. name@example.com' });
    }
    if (!message.value.trim() || message.value.trim().length < 10) {
      errors.push({ field: message, message: 'Please enter a message (at least 10 characters)' });
    }

    if (errors.length > 0) {
      errors.forEach(({ field, message }) => {
        field.setAttribute('aria-invalid', 'true');
        const errorEl = document.createElement('p');
        errorEl.className = 'error-message';
        errorEl.id = `${field.id}-error`;
        errorEl.setAttribute('role', 'alert');
        errorEl.innerHTML = '<span aria-hidden="true">\u26A0\uFE0F </span><strong>Error:</strong> ' +
          message.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
        field.setAttribute('aria-describedby', errorEl.id);
        field.parentElement?.appendChild(errorEl);
      });
      errors[0].field.focus();
      return;
    }

    // Submit
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
      });

      if (response.ok) {
        status.innerHTML = '<p class="success-message">Thank you for your message. We will be in touch soon.</p>';
        form.reset();
      } else {
        status.innerHTML = '<p class="error-message" role="alert"><span aria-hidden="true">\u26A0\uFE0F </span><strong>Error:</strong> Something went wrong. Please try again or email us directly.</p>';
      }
    } catch {
      status.innerHTML = '<p class="error-message">Something went wrong. Please try again or email us directly.</p>';
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send Message';
    }
  });
</script>

<style>
  /* How to Join */
  .how-to-join {
    padding: var(--space-16) 0;
    background: var(--color-bg);
  }

  .steps {
    display: grid;
    gap: var(--space-6);
    margin-top: var(--space-8);
  }

  @media (min-width: 768px) {
    .steps {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .step {
    text-align: center;
    padding: var(--space-6);
  }

  .step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: var(--radius-full);
    background: var(--color-green-800);
    color: white;
    font-family: var(--font-heading);
    font-size: var(--text-h3);
    font-weight: 700;
    margin-bottom: var(--space-4);
  }

  .step h3 {
    font-family: var(--font-heading);
    font-size: var(--text-h4);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-3);
  }

  .step p {
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: 1.6;
    color: var(--color-text-muted);
  }

  /* Fees */
  .fees {
    padding: var(--space-16) 0;
    background: var(--color-bg-alt);
  }

  .fees-table-wrapper {
    margin-top: var(--space-8);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .fees-table {
    width: 100%;
    border-collapse: collapse;
  }

  .fees-table thead {
    background: var(--color-green-800);
  }

  .fees-table th {
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 600;
    color: white;
    text-align: left;
    padding: var(--space-4);
  }

  .fees-table td {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text-muted);
    padding: var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  .fees-table td strong {
    color: var(--color-text);
  }

  .fees-table tbody tr:nth-child(even) td {
    background: var(--color-bg-alt);
  }

  .fees-table tbody tr:last-child td {
    border-bottom: none;
  }

  .fee-amount {
    font-weight: 600;
    color: var(--color-text);
    white-space: nowrap;
  }

  .fees-note {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-top: var(--space-4);
  }

  /* Responsive table: stack on mobile */
  @media (max-width: 639px) {
    .fees-table thead {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
    }

    .fees-table tr {
      display: block;
      padding: var(--space-4);
      border-bottom: 1px solid var(--color-border);
    }

    .fees-table td {
      display: block;
      padding: var(--space-1) 0;
      border-bottom: none;
    }

    .fees-table td::before {
      display: block;
      font-size: var(--text-xs);
      font-weight: 600;
      text-transform: uppercase;
      color: var(--color-text-light);
      letter-spacing: 0.04em;
    }

    .fees-table td:nth-child(1)::before { content: "Category"; }
    .fees-table td:nth-child(2)::before { content: "Eligibility"; }
    .fees-table td:nth-child(3)::before { content: "Annual Fee"; }
  }

  /* Beginners */
  .beginners {
    padding: var(--space-16) 0;
    background: var(--color-bg);
  }

  .beginners-layout {
    display: grid;
    gap: var(--space-8);
    margin-top: var(--space-8);
  }

  @media (min-width: 768px) {
    .beginners-layout {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
  }

  .beginners-text p {
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: 1.6;
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  .course-card {
    background: var(--color-green-100);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    border: 1px solid var(--color-border);
  }

  .course-card h3 {
    font-family: var(--font-heading);
    font-size: var(--text-h3);
    font-weight: 600;
    color: var(--color-green-800);
    margin-bottom: var(--space-4);
  }

  .course-details {
    margin: 0;
  }

  .detail-row {
    display: flex;
    gap: var(--space-4);
    padding: var(--space-3) 0;
    border-bottom: 1px solid rgba(14, 80, 56, 0.15);
  }

  .detail-row:last-child {
    border-bottom: none;
  }

  .detail-row dt {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-green-800);
    min-width: 100px;
    flex-shrink: 0;
  }

  .detail-row dd {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
  }

  /* Contact Form */
  .contact-section {
    padding: var(--space-16) 0;
    background: var(--color-bg-alt);
  }

  .form-wrapper {
    max-width: 640px;
    margin-top: var(--space-8);
  }

  .required-legend {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
  }

  .form-group {
    margin-bottom: var(--space-5);
  }

  .form-group label {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: var(--space-2);
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    min-height: 44px;
    padding: var(--space-3);
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .form-group textarea {
    min-height: 120px;
    resize: vertical;
  }

  .form-group input:focus-visible,
  .form-group textarea:focus-visible {
    outline: 2px solid var(--color-green-600);
    outline-offset: 1px;
    border-color: var(--color-green-600);
    box-shadow: 0 0 0 3px rgba(20, 122, 79, 0.4);
  }

  .form-group input:focus:not(:focus-visible),
  .form-group textarea:focus:not(:focus-visible) {
    outline: none;
  }

  .form-group input[aria-invalid="true"],
  .form-group textarea[aria-invalid="true"] {
    border-color: var(--color-error);
  }

  .btn-primary {
    display: inline-block;
    background: var(--color-green-800);
    color: white;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--text-sm);
    letter-spacing: 0.03em;
    text-transform: uppercase;
    padding: 12px 28px;
    border-radius: var(--radius-md);
    border: none;
    cursor: pointer;
    min-height: 44px;
    transition: background var(--transition-fast), transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .btn-primary:hover {
    background: var(--color-green-700);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(15, 80, 56, 0.25);
  }

  .btn-primary:focus-visible {
    outline: 2px solid var(--color-gold-600);
    outline-offset: 2px;
  }

  .btn-primary:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  @media (max-width: 639px) {
    .btn-primary {
      width: 100%;
    }
  }

  .form-status :global(.success-message) {
    margin-top: var(--space-4);
    padding: var(--space-4);
    background: #e8f5ee;
    color: #0F5038;
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: var(--text-base);
  }

  :global(.error-message) {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-error);
    margin-top: var(--space-1);
  }

  @media (prefers-reduced-motion: reduce) {
    .form-group input,
    .form-group textarea,
    .btn-primary {
      transition-duration: 0.01ms !important;
    }
  }
</style>
